#!/bin/sh
# Minimal init script for fastest boot time
# Use this for stateless VMs where backup/restore is not needed
#
# This script:
# - Mounts proc filesystem
# - Remounts root with optimized size
# - Executes main init
#
# Boot time savings: ~300-500ms compared to standard init

mount proc
mount / -o remount,size=90%
umount proc
exec /sbin/init
