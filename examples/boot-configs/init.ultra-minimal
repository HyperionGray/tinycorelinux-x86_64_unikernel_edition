#!/bin/sh
# Ultra-minimal init - absolute fastest boot
# WARNING: This removes nearly all features
# Only use for highly specialized deployments
#
# What this does:
# - Mount proc
# - Execute init
#
# What this skips:
# - All date setting
# - All backup/restore logic
# - All configuration parsing
# - All conditional logic
#
# Boot time savings: ~500-800ms compared to standard init

/bin/mount -t proc proc /proc
exec /sbin/init
